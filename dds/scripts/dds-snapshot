#!/usr/bin/env sh

# DDS SNAPSHOT BUILDER
#
# Назначение:
#   Формирует единый текстовый документ (Снимок) из файлов проекта.
#
# Архитектурные принципы:
#   1. Agnostic Output: Пишет в stdout или файл.
#   2. Protocol Strictness: Строгое соблюдение формата заголовков и порядка блоков.
#   3. Input Safety: Четкое разделение данных и метаданных.

usage() {
  cat << EOF
Формирует Полный Снимок проекта в соответствии с протоколом DDS.

Использование: $(basename "$0") [ОПЦИИ] [ПУТЬ...]

Опции ввода:
  --request "<текст>"    Добавить текст Запроса Действия (строковый литерал).
  --request-file <файл>  Добавить текст Запроса Действия из файла.

Опции вывода:
  --output <файл>        Сохранить вывод в файл вместо stdout.

Опции справки:
  --help                 Показать это сообщение.
EOF
}

fail() {
  printf "ERROR: %s\n" "$1" >&2
  exit 1
}

# --- Configuration & Dependencies ---

script_dir=$(CDPATH="" cd -- "$(dirname -- "$0")" && pwd)
DDS_LINTER="$script_dir/dds-linter"
DDS_LIST="$script_dir/dds-list"
DDS_TREE="$script_dir/dds-tree"

for tool in "$DDS_LINTER" "$DDS_LIST" "$DDS_TREE"; do
  if ! [ -x "$tool" ]; then fail "Зависимость не найдена или не исполняема: $tool"; fi
done

output_file=""
request_content=""
path_args=""

# --- Argument Parsing ---

while [ "$#" -gt 0 ]; do
  case "$1" in
    --help) usage; exit 0 ;;
    
    --output)
      [ -z "$2" ] && fail "--output требует аргумент"
      output_file="$2"
      shift 2
      ;;
      
    --request)
      [ -z "$2" ] && fail "--request требует аргумент"
      request_content="$2"
      shift 2
      ;;
      
    --request-file)
      [ -z "$2" ] && fail "--request-file требует аргумент"
      req_file="$2"
      if [ ! -f "$req_file" ]; then fail "Файл запроса не найден: $req_file"; fi
      request_content=$(cat "$req_file")
      shift 2
      ;;
    
    -*) fail "Неизвестная опция '$1'" ;;
    
    *) 
      path_args="$path_args \"$1\""
      shift 
      ;;
  esac
done

if [ -z "$path_args" ]; then
  set -- "."
else
  eval set -- "$path_args"
fi

# --- Temporary Files ---

tmp_dir="${TMPDIR:-/tmp}"
tmp_linter="$tmp_dir/dds_snap_lint_$$"
tmp_list="$tmp_dir/dds_snap_list_$$"
tmp_tree="$tmp_dir/dds_snap_tree_$$"

cleanup() {
  rm -f "$tmp_linter" "$tmp_list" "$tmp_tree"
}
trap cleanup EXIT

# --- Step 1: Verification (Linter) ---

# Запускаем линтер. Ошибки (exit 1) фатальны. Предупреждения (exit 2) допустимы.
if ! "$DDS_LINTER" "$@" > "$tmp_linter"; then
  err_code=$?
  if [ "$err_code" -eq 1 ]; then
    cat "$tmp_linter" >&2
    fail "Проверка структуры проекта не пройдена (см. ошибки выше)."
  fi
fi

# --- Step 2: Context Collection ---

# Генерируем дерево (STRUCTURE)
if ! "$DDS_TREE" "$@" > "$tmp_tree"; then
  fail "Генерация дерева файлов не удалась."
fi

# Генерируем список файлов (LIST)
if ! "$DDS_LIST" "$@" > "$tmp_list"; then
  fail "Генерация списка файлов не удалась."
fi

if [ ! -s "$tmp_list" ]; then
  fail "Список файлов пуст. Проверьте путь или .ddsignore."
fi

# --- Step 3: Content Processing Logic ---

# Функция вывода заголовка
print_header() {
  # $1: Тип/Название, $2: Путь (опционально), $3: Protected (0/1)
  _name="$1"
  _path="$2"
  _prot="$3"
  
  _prefix="DDS"
  if [ "$_prot" -eq 1 ]; then _prefix="DDS-PROTECTED"; fi
  
  if [ -n "$_path" ]; then
    # Добавлен разделитель -- перед строкой формата
    printf -- "---- [%s %s: %s] ----\n" "$_prefix" "$_name" "$_path"
  else
    printf -- "---- [%s %s] ----\n" "$_prefix" "$_name"
  fi
}

process_file_content() {
  _path="$1"
  _type="$2" # MANIFEST, META, SPEC, CONTENT

  if [ ! -f "$_path" ]; then
    printf "[File Not Found]\n"
    return
  fi

  # MANIFEST, META, SPEC всегда текстовые
  if [ "$_type" = "MANIFEST" ] || [ "$_type" = "SPEC" ] || [ "$_type" = "META" ]; then
    # cat "$_path"
    nl -ba -w1 -s'|' "$_path"
    return
  fi

  # Для CONTENT проверяем на бинарность (наличие нулевого байта в первых 1024 байтах)
  is_binary=0
  if command -v od >/dev/null 2>&1; then
    if od -N 1024 -t x1 "$_path" 2>/dev/null | grep -q ' 00 '; then is_binary=1; fi
  else
    # Fallback, если od нет (маловероятно на POSIX, но все же)
    if file -b --mime-encoding "$_path" 2>/dev/null | grep -q "binary"; then is_binary=1; fi
  fi

  if [ "$is_binary" -eq 1 ]; then
    return 1 # Signal binary
  else
    # Текстовый файл -> редукция
    awk '
      {
        line_len = length($0)
        limit = 400

        if (line_len <= limit) {
          print $0
          next
        }

        clean = $0
        gsub(/[^0-9,.\- x]/, "", clean)
        density = length(clean) / line_len

        if (density > 0.6) {
          head = substr($0, 1, 100)
          tail = substr($0, line_len - 50)
          printf "%s ... DDS REDUCED ... %s\n", head, tail
        } else {
          print $0
        }
      }
    ' "$_path"
    return 0
  fi
}

# --- Step 4: Stream Generation ---

generate_stream() {
  # 1. Project Structure
  print_header "PROJECT STRUCTURE" "" 0
  cat "$tmp_tree"
  printf "\n"

  # 2. Snapshot List
  print_header "SNAPSHOT LIST" "" 0
  cat "$tmp_list"
  printf "\n"

  # 3. Linter Report
  if [ -s "$tmp_linter" ]; then
    print_header "LINTER REPORT" "" 0
    cat "$tmp_linter"
    printf "\n"
  fi

  # 4. Files
  while IFS= read -r line <&3; do
    meta="${line%%: *}"
    path="${line#*: }"
    type="${meta%% *}"
    
    is_protected=0
    case "$meta" in *"PROTECTED"*) is_protected=1 ;; esac

    block_title="$type"
    
    if [ "$type" = "CONTENT" ]; then
      is_binary=0
      if [ -f "$path" ]; then
         if od -N 1024 -t x1 "$path" 2>/dev/null | grep -q ' 00 '; then is_binary=1; fi
      fi
      
      if [ "$is_binary" -eq 1 ]; then
        block_title="INFO OF"
        print_header "$block_title" "$path" "$is_protected"
        if command -v file >/dev/null 2>&1; then
           file -b "$path" 2>/dev/null || echo "Binary file"
        else
           echo "Binary file"
        fi
        if _size_bytes=$(wc -c < "$path" 2>/dev/null); then
           _size_clean=$(echo $_size_bytes)
           printf "Size: %s bytes\n" "$_size_clean"
        fi
      else
        block_title="CONTENT OF"
        print_header "$block_title" "$path" "$is_protected"
        process_file_content "$path" "$type"
      fi
    else
      print_header "$block_title" "$path" "$is_protected"
      if [ -f "$path" ]; then
        cat "$path"
      else
        printf "[File Not Found]\n"
      fi
    fi
    printf "\n"

  done 3< "$tmp_list"

  # 5. Request
  if [ -n "$request_content" ]; then
    print_header "REQUEST" "" 0
    printf '%s\n' "$request_content"
    printf '\n'
  fi

  # 6. End
  print_header "END OF SNAPSHOT" "" 0
}

if [ -n "$output_file" ]; then
  generate_stream > "$output_file"
else
  generate_stream
fi

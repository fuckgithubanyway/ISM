#!/usr/bin/env sh

usage() {
  cat << EOF
Интерпретирует и применяет План Изменений к проекту.

Использование: $(basename "$0") [--help] [--input <файл>] [путь]

Опции:
  --help        Показать это сообщение и выйти.
  --input <файл>  Прочитать План из файла (по умолчанию: stdin).

Аргументы:
  [путь]        Базовая директория проекта (по умолчанию: текущая).
EOF
}

fail() {
  printf "ERROR: %s\n" "$1" >&2
  exit 1
}

# Парсинг опций
input_file=""
base_dir="."
while [ "$#" -gt 0 ]; do
  case "$1" in
    --help) usage; exit 0 ;;
    --input) shift; input_file="$1" ;;
    -*) fail "Неизвестная опция '$1'" ;;
    *) base_dir="$1" ;;
  esac
  shift
done

if [ -n "$input_file" ]; then
  if [ ! -f "$input_file" ]; then fail "Файл '$input_file' не существует."; fi
  exec < "$input_file"
fi

# State machine
current_header=""
current_content=""
state=""
patch_path=""
patch_search=""
patch_replace=""

process_block() {
  if [ -z "$current_header" ]; then return; fi

  directive=$(printf "%s" "$current_header" | cut -d: -f1 | sed 's/ $//')
  arg=$(printf "%s" "$current_header" | sed 's/[^:]*: //')

  content="$current_content"

  case "$directive" in
    DDS COMMENT)
      : # Игнор
      ;;

    DDS MAKE DIR)
      path="$arg"
      mkdir -p "$base_dir/$path" || fail "Не удалось создать директорию '$path'"
      printf "INFO: Создано директорию: %s\n" "$path"
      ;;

    DDS UPSERT)
      path="$arg"
      dir=$(dirname "$path")
      mkdir -p "$base_dir/$dir" || fail "Не удалось создать директорию '$dir'"
      printf "%s" "$content" > "$base_dir/$path" || fail "Не удалось записать '$path'"
      printf "INFO: UPSERT файла: %s\n" "$path"
      ;;

    DDS RENAME)
      old=$(printf "%s" "$arg" | sed 's/ -> .*//')
      new=$(printf "%s" "$arg" | sed 's/.* -> //')
      mv "$base_dir/$old" "$base_dir/$new" || fail "Не удалось переименовать '$old' в '$new'"
      printf "INFO: Переименовано: %s -> %s\n" "$old" "$new"
      ;;

    DDS DELETE)
      path="$arg"
      rm -r "$base_dir/$path" || fail "Не удалось удалить '$path'"
      printf "INFO: Удалено: %s\n" "$path"
      ;;

    DDS COPY)
      source=$(printf "%s" "$arg" | sed 's/ -> .*//')
      target=$(printf "%s" "$arg" | sed 's/.* -> //')
      cp -r "$base_dir/$source" "$base_dir/$target" || fail "Не удалось скопировать '$source' в '$target'"
      printf "INFO: Скопировано: %s -> %s\n" "$source" "$target"
      ;;

    DDS APPEND)
      path="$arg"
      printf "%s" "$content" >> "$base_dir/$path" || fail "Не удалось добавить в '$path'"
      printf "INFO: Добавлено в файл: %s\n" "$path"
      ;;

    DDS SET ATTR)
      path=$(printf "%s" "$arg" | sed 's/ .*//')
      # Assume mode is in content as mode: 0755
      mode=$(printf "%s" "$content" | sed 's/mode: //')
      chmod -R "$mode" "$base_dir/$path" || fail "Не удалось установить атрибуты для '$path'"
      printf "INFO: Установлены атрибуты для %s (mode: %s)\n" "$path" "$mode"
      ;;

    DDS PATCH)
      patch_path="$arg"
      state="expect_search"
      ;;

    DDS SEARCH)
      if [ "$state" != "expect_search" ]; then fail "Неожиданный DDS SEARCH"; fi
      patch_search="$arg"
      state="expect_replace"
      ;;

    DDS REPLACE)
      if [ "$state" != "expect_replace" ]; then fail "Неожиданный DDS REPLACE"; fi
      patch_replace="$arg"
      state=""
      apply_patch "$patch_path" "$patch_search" "$patch_replace"
      ;;

    *) fail "Неизвестная директива: $directive" ;;
  esac
}

apply_patch() {
  path="$1"
  search_raw="$2"
  replace_raw="$3"

  full_path="$base_dir/$path"
  tmp_file="$full_path.tmp$$"
  if [ ! -f "$full_path" ]; then fail "Файл не существует: $path"; fi

  # Unescape replace and fix $1 -> \1
  replace_fixed=$(printf "%s" "$replace_raw" | sed 's/\$0/\\0/g; s/\$1/\\1/g; s/\$2/\\2/g; s/\$3/\\3/g; s/\$4/\\4/g; s/\$5/\\5/g; s/\$6/\\6/g; s/\$7/\\7/g; s/\$8/\\8/g; s/\$9/\\9/g')
  actual_replace=$(printf "%b" "$replace_fixed")

  # Determine if regex
  if printf "%s" "$search_raw" | grep -q '^/.*/[gims]*$'; then
    is_regex="true"
    flags=$(printf "%s" "$search_raw" | sed 's/.*/\([gims]*\)$/\1/')
    pattern_raw=$(printf "%s" "$search_raw" | sed 's/^\/\(.*\)\/[gims]*$/\1/')
    actual_pattern=$(printf "%b" "$pattern_raw")
  else
    is_regex="false"
    actual_pattern=$(printf "%b" "$search_raw")
    flags=""
  fi

  # Use awk for apply and check
  awk -v pattern="$actual_pattern" -v replace="$actual_replace" -v flags="$flags" '
  BEGIN {
    g = (index(flags, "g") > 0)
    if (index(flags, "i") > 0 || index(flags, "s") > 0) {
      print "ERROR: Флаги i и s не поддерживаются" > "/dev/stderr"
      exit 1
    }
  }
  { full = full (NR > 1 ? "\n" : "") $0 }
  END {
    ofull = full
    n = 0
    new_full = ""
    pos = 1
    while (match(substr(full, pos), pattern, a)) {
      n++
      new_full = new_full substr(ofull, pos, RSTART - 1)
      r = replace
      for (j = 0; j <= 9; j++) {
        gsub("$" j, a[j], r)
      }
      new_full = new_full r
      pos = pos + RSTART + RLENGTH - 1
      if (g == 0) break
    }
    new_full = new_full substr(ofull, pos)
    if (n == 0) {
      print "ERROR: Поиск не найден" > "/dev/stderr"
      exit 1
    }
    if (g == 0 && n > 1) {
      print "ERROR: Множественные совпадения без g" > "/dev/stderr"
      exit 1
    }
    print new_full
  }' "$full_path" > "$tmp_file" || fail "Не удалось применить PATCH к '$path'"
  mv "$tmp_file" "$full_path"
  printf "INFO: PATCH применен к %s\n" "$path"
}

# Парсинг входа
current_content=""
while IFS= read -r line; do
  if printf "%s" "$line" | grep -q '^--- DDS .* ---$'; then
    process_block
    current_header=$(printf "%s" "$line" | sed 's/^--- //; s/ ---$//')
    current_content=""
  else
    current_content="$current_content$line\n"
  fi
done

process_block

if [ -n "$state" ]; then fail "Незавершенный PATCH"; fi

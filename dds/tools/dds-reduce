#!/usr/bin/awk -f

BEGIN {
    # Порог срабатывания: если в буфере больше N чисел, редуцируем
    THRESHOLD = 16
    buf_count = 0
}

# Функция проверки: является ли строка "строкой данных"
function is_data_line(str,   clean) {
    # 1. Удаляем комментарии (C-style и Python-style)
    sub(/\/\/.*$/, "", str)
    sub(/#.*$/, "", str)
    
    # 2. Если строка пустая - игнорируем
    if (str ~ /^[ \t]*$/) return 0
    
    # 3. Проверка на недопустимые символы.
    # Создаем копию строки для очистки
    clean = str
    
    # Удаляем ВСЕ допустимые символы для числовых массивов C/C++/JS/Python.
    # Разрешаем:
    # 0-9          : Цифры
    # a-f A-F      : Hex-цифры (для 0xFF)
    # x X          : Префикс Hex (0x)
    # . + -        : Математические знаки
    # e E          : Экспоненциальная запись (1.5e-10)
    # u U l L      : Суффиксы целых (100UL, 100ull)
    # f F          : Суффиксы float (1.0f)
    # , \t (space) : Разделители
    gsub(/[0-9a-fA-FxXuUlL.+\-eE, \t]/, "", clean)
    
    # Если остались символы (например: скобки, кавычки, =, ;, g, h, z...),
    # значит это код или текст, а не чистый массив данных.
    if (length(clean) > 0) return 0
    
    # 4. ВАЖНО: Строка обязана содержать хотя бы одну цифру 0-9.
    # Это предотвращает ложное срабатывание на слова из hex-символов, 
    # например: "add, beef, face" (переменные или enum'ы).
    # Hex-числа (0xABC) содержат 0. Float (1.0f) содержат цифры.
    if (str !~ /[0-9]/) return 0
    
    return 1
}

# Функция сброса буфера в вывод
function flush_buffer(   i, total_nums) {
    if (buf_count == 0) return

    # Считаем примерное количество чисел в буфере по запятым
    total_nums = 0
    for (i=1; i<=buf_count; i++) {
        # Считаем запятые + 1 (грубая оценка элементов)
        total_nums += gsub(/,/, ",", buffer[i]) + 1
    }

    # Логика редукции
    if (total_nums > THRESHOLD && buf_count >= 3) {
        # Выводим первую строку блока
        print buffer[1]
        
        # Выводим маркер с информацией
        print "        .... DDS REDUCED (approx " total_nums " items) ...."
        
        # Выводим последнюю строку блока
        print buffer[buf_count]
    } else {
        # Если блок маленький, выводим всё как есть
        for (i=1; i<=buf_count; i++) {
            print buffer[i]
        }
    }

    # Очистка
    delete buffer
    buf_count = 0
}

{
    if (is_data_line($0)) {
        # Если строка похожа на данные, накапливаем
        buf_count++
        buffer[buf_count] = $0
    } else {
        # Если встретили код - сбрасываем накопленное и печатаем текущую строку
        flush_buffer()
        print $0
    }
}

END {
    flush_buffer()
}

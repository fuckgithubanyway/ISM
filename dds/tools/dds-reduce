#!/usr/bin/env sh

# ==============================================================================
# DDS REDUCE v0.8 (Semantic Comma-Based Reduction)
# ==============================================================================

if ! command -v awk >/dev/null 2>&1; then
  cat
  exit 0
fi

awk '
BEGIN {
    # Минимальное количество элементов (запятых), чтобы считать строку "длинной"
    # 3 слева + 3 справа + 2 в середине = 8
    MIN_COMMAS_TO_REDUCE = 8
    
    # Состояние
    buf_len = 0
    cur_type = "NONE"
}

# --- FUNCTIONS ---

# Проверка: является ли строка "данными" (числа, скобки, запятые)
function get_line_type(str,   clean) {
    if (str ~ /^[ \t]*$/) return "EMPTY"
    if (str ~ /^[ \t]*(\/\/|#)/) return "COMMENT"

    clean = str
    # Удаляем допустимые символы данных
    gsub(/[ \t,0-9.\-eE+xXabcdefABCDEF\[\]\(\)\{\}]/, "", clean)
    
    # Если остались посторонние символы (например буквы переменных) -> CODE
    if (length(clean) > 0) return "CODE"
    
    # Если остались только допустимые, но нет цифр -> CODE (пустые скобки)
    if (str !~ /[0-9]/) return "CODE"
    
    return "DATA"
}

# Горизонтальная редукция по запятым
function reduce_line_semantically(str,   len, n, parts, i, start_idx, end_idx, commas_found, target_comma, head, tail, hidden_size) {
    
    # 1. Быстрая проверка длины
    if (length(str) < 60) return str

    # 2. Считаем запятые
    # split возвращает кол-во полей. Запятых = полей - 1
    n = split(str, parts, ",")
    if (n < MIN_COMMAS_TO_REDUCE) return str

    # 3. Находим позицию 3-й запятой (Конец HEAD)
    start_idx = 0
    commas_found = 0
    for(i=1; i<=length(str); i++) {
        if (substr(str, i, 1) == ",") {
            commas_found++
            if (commas_found == 3) {
                start_idx = i
                break
            }
        }
    }

    # 4. Находим позицию (Total-3)-й запятой (Начало TAIL)
    # Нам нужно оставить 3 элемента с конца. Значит нужно найти (TotalCommas - 2)-ю запятую
    target_comma = (n-1) - 2
    end_idx = 0
    commas_found = 0
    for(i=1; i<=length(str); i++) {
        if (substr(str, i, 1) == ",") {
            commas_found++
            if (commas_found == target_comma) {
                end_idx = i
                break
            }
        }
    }

    if (start_idx == 0 || end_idx == 0 || start_idx >= end_idx) return str

    # 5. Сборка
    head = substr(str, 1, start_idx)       # "data = [1, 2, 3,"
    tail = substr(str, end_idx)            # ", 98, 99, 100]"
    
    hidden_size = length(str) - length(head) - length(tail)
    
    return head " .... DDS REDUCED [" hidden_size " chars] .... " tail
}

function flush_buffer(   i, hidden_lines) {
    if (buf_len == 0) return

    # Логика:
    # Если блок данных > 4 строк, сворачиваем середину.
    # Если <= 4, печатаем всё (но применяем гориз. редукцию к каждой строке)
    
    if (buf_len > 4) {
        # HEAD (1-я строка)
        print reduce_line_semantically(buffer[1])
        
        # MARKER
        hidden_lines = buf_len - 2
        print "        .... DDS REDUCED [" hidden_lines " lines] ...."
        
        # TAIL (Последняя строка)
        print reduce_line_semantically(buffer[buf_len])
        
    } else {
        for (i=1; i<=buf_len; i++) {
            print reduce_line_semantically(buffer[i])
        }
    }

    delete buffer
    buf_len = 0
}

# --- MAIN LOOP ---

{
    line = $0
    type = get_line_type(line)

    if (type == "EMPTY" || type == "COMMENT") {
        flush_buffer()
        print line
        cur_type = "NONE"
        next
    }

    if (type == "CODE") {
        flush_buffer()
        print reduce_line_semantically(line)
        cur_type = "NONE"
        next
    }

    if (cur_type != "DATA") {
        flush_buffer()
        cur_type = "DATA"
    }

    buf_len++
    buffer[buf_len] = line
}

END {
    flush_buffer()
}
'

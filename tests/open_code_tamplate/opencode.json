{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "architect",
  "instructions": [
    "ism/-0-manifest-core.md",
    "ism/-1-manifest-topology.md",
    "ism/-2-manifest-workflow.md",
    "ism/-3-manifest-adr.md"
  ],
  "agent": {
    "build": { "disable": true },
    "plan":  { "disable": true },

    "general": { "disable": true },
    "explore": { "disable": true },

    "ism-architect": {
      "description": "ISM-Архитектор — анализ, планирование и работа ТОЛЬКО с Зоной Определения (ism/)",
      "color": "#87b028",
      "mode": "primary",
      "temperature": 0.333,
      "prompt": "{file:./-agent-architect.md}",
      "edit": { "*": "deny", "ism/**": "allow" },
      "bash": { "*": "deny", "ism/**": "allow" },
      "steps": 13
    },

    "ism-synthesizer": {
      "description": "ISM-Синтезатор — генерация артефактов ТОЛЬКО в Зоне Проекции (все кроме ism/)",
      "color": "#2858b0",
      "mode": "primary",
      "temperature": 0.0,
      "prompt": "{file:./-agent-synthesizer.md}",
      "edit": { "ism/**": "deny", "*": "allow" },
      "bash": { "ism/**": "deny", "*": "allow" },
      "steps": 7
    }
  }
}

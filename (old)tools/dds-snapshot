#!/usr/bin/env sh

set -u
export LC_ALL=C

usage() {
  cat << EOF
Usage: $(basename "$0") [OPTIONS] [PATH]

Options:
  --intent "TEXT"      Include natural language intent.
  --intent-file FILE   Read intent from file.
  --view FILE          Use specific projection file (.ddsview).
  --no-reduce          Disable automatic array reduction.
  --output FILE        Write output to file instead of stdout.
  --help               Show this message.

Arguments:
  PATH                 Project root (default: current).
EOF
}

fail() {
  printf "ERROR: %s\n" "$1" >&2
  exit 1
}

# --- Configuration ---
INTENT_TEXT=""
VIEW_FILE=""
NO_REDUCE=0
OUTPUT_FILE=""
TARGET_DIR="."

while [ "$#" -gt 0 ]; do
  case "$1" in
    --help) usage; exit 0 ;;
    --intent) 
      if [ -z "$2" ]; then fail "--intent requires an argument"; fi
      INTENT_TEXT="$2"; shift 2 ;;
    --intent-file)
      if [ -z "$2" ]; then fail "--intent-file requires an argument"; fi
      if [ ! -f "$2" ]; then fail "Intent file not found: $2"; fi
      INTENT_TEXT=$(cat "$2"); shift 2 ;;
    --view)
      if [ -z "$2" ]; then fail "--view requires an argument"; fi
      VIEW_FILE="$2"; shift 2 ;;
    --output)
      if [ -z "$2" ]; then fail "--output requires an argument"; fi
      OUTPUT_FILE="$2"; shift 2 ;;
    --no-reduce)           # <--- Добавлено
      NO_REDUCE=1; shift ;;
    -*) fail "Unknown option: $1" ;;
    *) TARGET_DIR="$1"; shift ;;
  esac
done

if [ ! -d "$TARGET_DIR" ]; then fail "Target directory not found: $TARGET_DIR"; fi

# --- Dependencies ---
SCRIPT_DIR=$(CDPATH="" cd -- "$(dirname -- "$0")" && pwd)
DDS_VERIFY="$SCRIPT_DIR/dds-verify"
DDS_TREE="$SCRIPT_DIR/dds-tree"
DDS_LIST="$SCRIPT_DIR/dds-list"

for tool in "$DDS_VERIFY" "$DDS_TREE" "$DDS_LIST"; do
  if [ ! -x "$tool" ]; then fail "Tool not found or not executable: $tool"; fi
done

# --- Temporary Files ---
TMP_DIR="${TMPDIR:-/tmp}"
T_VERIFY="$TMP_DIR/dds_snap_verify_$$"
T_TREE="$TMP_DIR/dds_snap_tree_$$"
T_LIST="$TMP_DIR/dds_snap_list_$$"

cleanup() {
  rm -f "$T_VERIFY" "$T_TREE" "$T_LIST"
}
trap cleanup EXIT

# --- Execution Phase ---

# 1. Protocol Verification
if [ -n "$VIEW_FILE" ]; then
  "$DDS_VERIFY" --view "$VIEW_FILE" "$TARGET_DIR" > "$T_VERIFY" 2>&1
else
  "$DDS_VERIFY" "$TARGET_DIR" > "$T_VERIFY" 2>&1
fi

verify_status=$?

# Если верификация не прошла - прерываем работу.
# dds-verify теперь возвращает exit 1 при наличии запрещенных строк.
if [ $verify_status -ne 0 ]; then
  cat "$T_VERIFY" >&2
  rm -f "$T_VERIFY" "$T_TREE" "$T_LIST"
  exit 1
fi

# 2. Project Structure
"$DDS_TREE" --plain "$TARGET_DIR" > "$T_TREE"

# 3. Context Index
if [ -n "$VIEW_FILE" ]; then
  "$DDS_LIST" --view "$VIEW_FILE" "$TARGET_DIR" > "$T_LIST"
else
  "$DDS_LIST" "$TARGET_DIR" > "$T_LIST"
fi

# --- Generation Phase ---

generate_stream() {
  # Header Helper
  print_header() {
    if [ -n "$2" ]; then
      printf -- "-%s DDS %s: %s ----\n" "---" "$1" "$2"
    else
      printf -- "-%s DDS %s ----\n" "---" "$1"
    fi
  }

  # 1. Project Structure
  print_header "PROJECT STRUCTURE" ""
  cat "$T_TREE"
  printf "\n"

  # 2. Context Index
  print_header "CONTEXT INDEX" ""
  cat "$T_LIST"
  printf "\n"

  # 3. Verification Report
  print_header "VERIFICATION REPORT" ""
  cat "$T_VERIFY"
  printf "\n"

  # 4. Content Loop
  while IFS= read -r line; do
    _type="${line%%: *}"
    _path="${line#*: }"
    
    if [ ! -f "$TARGET_DIR/$_path" ]; then continue; fi

    full_path="$TARGET_DIR/$_path"
    
    case "$_type" in
      MANIFEST) block_title="MANIFEST" ;;
      META)     block_title="META" ;;
      SPEC)     block_title="SPEC" ;;
      *)        block_title="CONTENT OF" ;;
    esac

    # Binary Detection
    is_binary=0
    if command -v od >/dev/null 2>&1; then
       if od -N 1024 -t x1 "$full_path" 2>/dev/null | grep -q ' 00 '; then is_binary=1; fi
    else
       if grep -qP '\x00' "$full_path" 2>/dev/null; then is_binary=1; fi
    fi

    if [ $is_binary -eq 1 ]; then
      print_header "INFO OF" "$_path"
      echo "Бинарный файл"
      if [ -x /usr/bin/stat ]; then
         ls -lh "$full_path" | awk '{print "Размер:", $5}'
      fi
    else
      print_header "$block_title" "$_path"
      
      if [ "$NO_REDUCE" -eq 0 ] && [ -x "$SCRIPT_DIR/dds-reduce" ]; then
          "$SCRIPT_DIR/dds-reduce" < "$full_path"
      else
          cat "$full_path"
      fi
      
    fi
    printf "\n"

  done < "$T_LIST"

  # 5. Intent
  print_header "INTENT" ""
  if [ -n "$INTENT_TEXT" ]; then
    printf "%s\n" "$INTENT_TEXT"
  else
    printf "Провести аудит текущего состояния.\n"
  fi
  printf "\n"

  print_header "END OF SNAPSHOT" ""
}

# --- Output Redirection ---
if [ -n "$OUTPUT_FILE" ]; then
  generate_stream > "$OUTPUT_FILE"
else
  generate_stream
fi
